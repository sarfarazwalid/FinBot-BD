# Application
APP_NAME=FinBot BD
APP_VERSION=1.0.0
DEBUG=false

# LLM (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-8b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Embeddings
EMBEDDING_PROVIDER=openrouter
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=finbot-bd
PINECONE_ENVIRONMENT=aws

# Retrieval
TOP_K=5
BM25_WEIGHT=0.3
SEMANTIC_WEIGHT=0.7

# Hugging Face (optional, only needed for private models)
HF_TOKEN=